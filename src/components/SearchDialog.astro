<dialog
  class="search-dialog"
  id="site-search"
  aria-labelledby="site-search-title"
  aria-describedby="site-search-description"
>
  <div class="search-dialog__panel">
    <header class="search-dialog__header">
      <div>
        <h2 id="site-search-title">搜索文章</h2>
        <p id="site-search-description">
          输入标题、分类、专栏、标签或正文关键词。
        </p>
      </div>
      <button
        class="search-dialog__close"
        type="button"
        aria-label="关闭搜索"
        data-search-close
      >
        <span aria-hidden="true">×</span>
      </button>
    </header>

    <input
      class="search-dialog__input"
      id="site-search-input"
      type="search"
      aria-label="搜索文章"
      placeholder="输入关键词"
      autocomplete="off"
      data-search-input
    />

    <p
      class="search-dialog__status"
      data-search-status
      data-search-loading="正在加载文章…"
      data-search-empty="没有找到相关文章"
      data-search-error="搜索暂不可用"
      aria-live="polite"
      aria-atomic="true"
    >
      输入关键词，或浏览最近更新。
    </p>

    <ol class="search-dialog__results" data-search-results></ol>

    <a class="search-dialog__fallback" href="/posts/">浏览文章归档</a>
  </div>
</dialog>

<script>
  import '../scripts/search-dialog';
</script>
