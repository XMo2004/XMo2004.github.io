---
import PostSeriesNavigation from '../components/PostSeriesNavigation.astro';
import RelatedPostList from '../components/RelatedPostList.astro';
import TagList from '../components/TagList.astro';
import { SITE } from '../config/site';
import type { ArticleHeading } from '../lib/feishu-headings';
import {
  getCategoryHref,
  getColumnHref,
  type AdjacentPostLink,
  type RelatedPostLink,
  type SeriesNavigation,
} from '../lib/posts';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  column?: string;
  columnOrder?: number;
  tags?: readonly string[];
  readingMinutes?: number;
  headings?: readonly ArticleHeading[];
  previous?: AdjacentPostLink;
  next?: AdjacentPostLink;
  series?: SeriesNavigation;
  related?: readonly RelatedPostLink[];
}

const {
  title,
  description,
  canonicalPath,
  pubDate,
  updatedDate,
  category,
  column,
  columnOrder,
  tags = [],
  readingMinutes,
  headings = [],
  previous,
  next,
  series,
  related = [],
} = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const displayColumnOrder = columnOrder === undefined
  ? undefined
  : String(columnOrder).padStart(2, '0');
const tableOfContents = headings.filter(
  (heading) =>
    heading.depth >= 2 &&
    heading.depth <= 4 &&
    heading.text.trim().length > 0 &&
    heading.slug.trim().length > 0,
);
const hasTableOfContents = tableOfContents.length >= 2;
const hasAdjacentPosts = previous !== undefined || next !== undefined;
const canonicalUrl = new URL(canonicalPath, SITE.canonicalOrigin).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  articleSection: category,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: SITE.author,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  isPartOf: column === undefined
    ? undefined
    : {
        '@type': 'CollectionPage',
        name: column,
        url: new URL(getColumnHref(column), SITE.canonicalOrigin).href,
      },
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="post-article">
    <header class="post-header">
      <a class="post-header__back" href="/posts/">文章归档</a>
      <h1>{title}</h1>
      <p class="post-header__description">{description}</p>

      <dl class="article-meta">
        <div>
          <dt>发布</dt>
          <dd>
            <time datetime={pubDate.toISOString()}>{dateFormatter.format(pubDate)}</time>
          </dd>
        </div>

        {updatedDate && (
          <div>
            <dt>更新</dt>
            <dd>
              <time datetime={updatedDate.toISOString()}>
                {dateFormatter.format(updatedDate)}
              </time>
            </dd>
          </div>
        )}

        {readingMinutes !== undefined && (
          <div>
            <dt>阅读</dt>
            <dd>{readingMinutes} 分钟</dd>
          </div>
        )}

      </dl>

      <nav class="post-header__taxonomies" aria-label="文章分类与标签">
        <a class="post-header__category" href={getCategoryHref(category)}>
          {category}
        </a>

        {column !== undefined && displayColumnOrder !== undefined && (
          <a class="post-header__column" href={getColumnHref(column)}>
            <span aria-label={`专栏第 ${columnOrder} 篇`}>{displayColumnOrder}</span>
            <span>{column}</span>
          </a>
        )}

        <TagList tags={tags} compact />
      </nav>
    </header>

    <div
      class:list={[
        'post-layout',
        hasTableOfContents && 'post-layout--with-toc',
      ]}
    >
      {hasTableOfContents && (
        <aside
          class="post-toc post-toc--desktop"
          aria-labelledby="post-toc-title"
        >
          <p id="post-toc-title">目录</p>
          <nav aria-label="文章目录">
            <ol>
              {tableOfContents.map((heading) => (
                <li class={`post-toc__depth-${heading.depth}`}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )}

      <div class="post-layout__content">
        {hasTableOfContents && (
          <details class="post-toc-compact">
            <summary>本页目录</summary>
            <nav aria-label="折叠文章目录">
              <ol>
                {tableOfContents.map((heading) => (
                  <li class={`post-toc__depth-${heading.depth}`}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ol>
            </nav>
          </details>
        )}

        <div class="prose"><slot /></div>

        {series ? (
          <PostSeriesNavigation series={series} />
        ) : (
          hasAdjacentPosts && (
            <nav class="post-pagination" aria-label="相邻文章">
              {previous && (
                <a class="post-pagination__previous" href={previous.href} rel="prev">
                  <span>上一篇</span>
                  <strong>{previous.title}</strong>
                </a>
              )}
              {next && (
                <a class="post-pagination__next" href={next.href} rel="next">
                  <span>下一篇</span>
                  <strong>{next.title}</strong>
                </a>
              )}
            </nav>
          )
        )}

        {related.length > 0 && (
          <RelatedPostList posts={related} />
        )}
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-toc-compact {
    display: none;
  }

  @media (max-width: 64rem) {
    .post-toc-compact {
      display: block;
    }
  }
</style>
