---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';

import PostLayout from '../../layouts/PostLayout.astro';
import { extractFeishuHeadings } from '../../lib/feishu-headings';
import {
  buildPostRouteRecords,
  buildRelatedPosts,
  buildSeriesNavigation,
  estimateReadingMinutes,
  getPostHref,
  sortNewestFirst,
  type AdjacentPostLink,
  type RelatedPostLink,
  type SeriesNavigation,
} from '../../lib/posts';

interface Props {
  post: CollectionEntry<'posts'>;
  previous?: AdjacentPostLink;
  next?: AdjacentPostLink;
  series?: SeriesNavigation;
  related: RelatedPostLink[];
}

export async function getStaticPaths() {
  const posts = sortNewestFirst(await getCollection('posts'));
  const routeRecords = buildPostRouteRecords(posts);

  return routeRecords.map((route) => {
    const series = buildSeriesNavigation(posts, route.props.post.id);
    const excluded = new Set([
      route.props.previous?.href,
      route.props.next?.href,
      series?.previous?.href,
      series?.next?.href,
    ].filter((href): href is string => href !== undefined));
    const related = buildRelatedPosts(posts, route.props.post.id, {
      excludeHrefs: excluded,
      limit: 3,
    });

    return {
      ...route,
      props: { ...route.props, series, related },
    };
  });
}

const { post, previous, next, series, related } = Astro.props;
const { Content, headings } = await render(post);

if (post.body === undefined) {
  throw new Error(`Post "${post.id}" does not expose its Markdown body.`);
}

const controlledHeadings = extractFeishuHeadings(post.body);
const articleHeadings = controlledHeadings ?? headings;
const readingMinutes = estimateReadingMinutes(post.body);
const canonicalPath = getPostHref(post);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  canonicalPath={canonicalPath}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  category={post.data.category}
  column={post.data.column}
  columnOrder={post.data.columnOrder}
  tags={post.data.tags}
  readingMinutes={readingMinutes}
  headings={articleHeadings}
  previous={previous}
  next={next}
  series={series}
  related={related}
>
  <Content />
</PostLayout>
