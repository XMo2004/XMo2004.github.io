---
import { getCollection } from 'astro:content';

import PostCard from '../components/PostCard.astro';
import { SITE } from '../config/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import { sortNewestFirst } from '../lib/posts';

const posts = sortNewestFirst(await getCollection('posts'));
const featured = posts.filter((post) => post.data.featured);
const latest = posts.filter((post) => !post.data.featured).slice(0, 3);
---

<BaseLayout title={SITE.name} description={SITE.description}>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero__copy">
      <p class="eyebrow">{SITE.mark}</p>
      <h1 id="home-title">关于技术、成长与日常的长期笔记。</h1>
      <p class="home-hero__intro">
        把实践过程、阶段思考与具体观察写清楚，也让值得保留的内容拥有稳定的静态归档。
      </p>
      <div class="home-hero__actions">
        <a class="button" href="/posts/">浏览全部文章</a>
        <a class="text-link" href="/about/">了解这个博客</a>
      </div>
    </div>

    <aside class="editorial-note" aria-label="博客说明">
      <span>WRITE</span>
      <strong>缓慢记录</strong>
      <span>ARCHIVE</span>
      <strong>长期整理</strong>
    </aside>
  </section>

  <section class="home-section" aria-labelledby="featured-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">EDITOR'S PICK</p>
        <h2 id="featured-title">精选文章</h2>
      </div>
      <p>从真实的写作归档中挑选。</p>
    </div>

    {featured.length > 0 ? (
      <div class="post-grid post-grid--featured">
        {featured.map((post) => <PostCard entry={post} headingLevel="h3" />)}
      </div>
    ) : (
      <p class="empty-state">暂时还没有设为精选的文章。</p>
    )}
  </section>

  <section class="home-section" aria-labelledby="latest-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">RECENT NOTES</p>
        <h2 id="latest-title">最新文章</h2>
      </div>
      <a class="standalone-action" href="/posts/">查看文章归档</a>
    </div>

    {latest.length > 0 ? (
      <div class="post-grid">
        {latest.map((post) => <PostCard entry={post} headingLevel="h3" />)}
      </div>
    ) : (
      <p class="empty-state">新的文章还在整理中，可以先读上面的精选。</p>
    )}
  </section>
</BaseLayout>
