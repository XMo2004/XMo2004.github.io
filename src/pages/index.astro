---
import { getCollection } from 'astro:content';

import PostCard from '../components/PostCard.astro';
import PostRow from '../components/PostRow.astro';
import { SITE } from '../config/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  buildCategoryIndex,
  buildColumnIndex,
  getCategoryHref,
  getColumnHref,
  sortNewestFirst,
} from '../lib/posts';

const posts = sortNewestFirst(await getCollection('posts'));
const categoryIndex = buildCategoryIndex(posts);
const columnIndex = buildColumnIndex(posts);
const featured = posts.find((post) => post.data.featured);
const latest = posts.filter((post) => post !== featured).slice(0, 4);
---

<BaseLayout title={SITE.name} description={SITE.description}>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero__copy">
      <p class="eyebrow">{SITE.mark}</p>
      <h1 id="home-title" aria-label="xmo 的博客">
        <span class="home-title__xmo" aria-hidden="true">
          <span>x</span><span>m</span><span>o</span>
        </span>
        <span class="home-title__suffix" aria-hidden="true">的博客</span>
      </h1>
    </div>

    <svg
      class="home-brand-mark"
      viewBox="0 0 300 120"
      aria-hidden="true"
      focusable="false"
    >
      <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 18 82 102M82 18 18 102" />
        <path d="M112 102V18l35 48 35-48v84" />
        <ellipse cx="242" cy="60" rx="40" ry="43" />
      </g>
    </svg>
  </section>

  <section class="home-taxonomy" aria-label="内容索引">
    <div class="home-taxonomy__group">
      <div class="home-taxonomy__heading">
        <p class="eyebrow">CATEGORIES</p>
        <h2>分类</h2>
        <a href="/categories/">全部分类</a>
      </div>
      <ul class="home-taxonomy__list">
        {categoryIndex.map((category) => (
          <li>
            <a href={getCategoryHref(category.label)}>
              <span>{category.label}</span>
              <small>{category.posts.length}</small>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="home-taxonomy__group">
      <div class="home-taxonomy__heading">
        <p class="eyebrow">COLUMNS</p>
        <h2>专栏</h2>
        <a href="/columns/">全部专栏</a>
      </div>
      <ul class="home-taxonomy__list">
        {columnIndex.map((column) => (
          <li>
            <a href={getColumnHref(column.label)}>
              <span>{column.label}</span>
              <small>{column.posts.length}</small>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="home-section" aria-labelledby="featured-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">EDITOR'S PICK</p>
        <h2 id="featured-title">精选文章</h2>
      </div>
      <p>从真实的写作归档中挑选。</p>
    </div>

    {featured ? (
      <div class="post-grid post-grid--featured">
        <PostCard entry={featured} headingLevel="h3" />
      </div>
    ) : (
      <p class="empty-state">暂时还没有设为精选的文章。</p>
    )}
  </section>

  <section class="home-section" aria-labelledby="latest-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">RECENT NOTES</p>
        <h2 id="latest-title">最新文章</h2>
      </div>
      <a class="standalone-action" href="/posts/">查看文章归档</a>
    </div>

    {latest.length > 0 ? (
      <div class="post-row-list">
        {latest.map((post) => <PostRow entry={post} headingLevel="h3" />)}
      </div>
    ) : (
      <p class="empty-state">新的文章还在整理中。</p>
    )}
  </section>
</BaseLayout>
